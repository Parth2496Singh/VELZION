# ==============================================================================
# 🌐 VELZION UNIFIED ENVIRONMENT VARIABLES
# ==============================================================================
# Save this file as '.env' in the root of your project.
# Both local and EC2 deployments will read from this single file.

# ------------------------------------------------------------------------------
# 1. EXTERNAL DATABASE (The architectural shift for shared state)
# Provide your external Postgres details here (e.g., Supabase, Neon, AWS RDS).
# Both Django and n8n will connect to this exact same database.
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://your_user:your_password@your_external_db_host:5432/velzion

# n8n Database Mapping (Connects n8n to the same Postgres instance)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=your_external_db_host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=velzion
DB_POSTGRESDB_USER=your_user
DB_POSTGRESDB_PASSWORD=your_password

# ------------------------------------------------------------------------------
# 2. DJANGO BACKEND SECRETS
# ------------------------------------------------------------------------------
# Any random string (used for cryptographic signing). DO NOT share your production key!
DJANGO_SECRET_KEY=velzion-insecure-key-for-local-dev-only
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your_ec2_ip
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://your_ec2_ip

# ------------------------------------------------------------------------------
# 3. GITHUB OAUTH CREDENTIALS
# ------------------------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ------------------------------------------------------------------------------
# 4. N8N & AUTOMATION SECRETS
# ------------------------------------------------------------------------------
# Any random secure string used to verify webhook requests between Django & n8n
N8N_WEBHOOK_SECRET=my-super-secret-webhook-key-123

# The internal network URL where n8n can reach Django (Do not change for Docker)
BACKEND_INTERNAL_URL=http://backend:8000

# Your Personal Access Token for GitHub API (Required for PR comments)
GITHUB_PAT=your_github_personal_access_token_here

# ------------------------------------------------------------------------------
# 5. N8N SYSTEM SETTINGS
# ------------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production
WEBHOOK_URL=http://localhost:5678/
N8N_ENABLE_EXECUTE_COMMAND=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# ------------------------------------------------------------------------------
# 6. AWS CLOUD CREDENTIALS (Replaces ~/.aws mount for production)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ------------------------------------------------------------------------------
# 7. FRONTEND VARIABLES (Passed during build/run)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook
FRONTEND_URL=http://localhost:5173
